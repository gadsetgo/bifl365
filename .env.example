# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI APIs
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Pipeline (optional — defaults shown as comments)
# PIPELINE_RESEARCH_SOURCE=local        # local | online | import
# PIPELINE_RESEARCH_PROVIDER=ollama     # ollama | gemini | claude
# PIPELINE_SCORING_PROVIDER=ollama      # ollama | gemini | claude | none
# PIPELINE_CONTENT_PROVIDER=ollama      # ollama | gemini | claude | none
# CLAUDE_MODEL=claude-haiku-4-5-20251001
# PIPELINE_SKIP_UPSERT=false            # true to test without writing to DB
# PIPELINE_TOTAL_CANDIDATES=3
# PIPELINE_UPSERT_MODE=direct           # direct | api
# PIPELINE_IMPORT_DIR=./research-drop   # folder watched by pipeline:dropbox
# PIPELINE_IMPORT_FILE=                 # path to a single import JSON file
# PIPELINE_IMPORT_SELECTION=all         # all | latest (dropbox folder mode)
# PIPELINE_IMPORT_ARCHIVE=true          # move processed files to processed/ dir
# OLLAMA_MODEL=phi3:latest
# OLLAMA_HOST=localhost
# OLLAMA_PORT=11434
GEMINI_MODEL=gemini-2.5-flash         # used by pipeline + admin rewrite API
